# Local development uses SQLite (zero-setup, file-based).
# DB file lives at api/aziza.db relative to where you run uvicorn.
DATABASE_URL=sqlite+aiosqlite:///./aziza.db

# Auth
SECRET_KEY=change-me-in-prod
ACCESS_TOKEN_TTL_MIN=15
REFRESH_TOKEN_TTL_DAYS=30

# CORS — origins allowed to call the API (Flutter web dev server)
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080","http://localhost:5173","http://localhost:64000"]

ENVIRONMENT=development

# === PRODUCTION (uncomment + set when going live) ===
# DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/aziza
# REDIS_URL=redis://HOST:6379/0
# See docs/PRODUCTION.md for managed-DB recommendations.
